{
  "name": "webhostservice",
  "version": "1.0.0",
  "description": "Web development and hosting service platform for R&L Labs",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspace=client",
    "install:all": "npm install && npm install --workspace=client && npm install --workspace=server"
  },
  "keywords": [
    "web-hosting",
    "web-development",
    "service-platform"
  ],
  "author": "R&L Labs",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
